# Strict engines: install fails if Node/pnpm don't match package.json#engines
engine-strict=true

# Lockfile must match exactly — no silent drift in CI / K8s
prefer-frozen-lockfile=true

# Package manager pinned by package.json#packageManager (refuse if mismatched)
package-manager-strict=true
package-manager-strict-version=false

# Supply-chain hardening: refuse packages published less than 7 days ago
minimumReleaseAge=10080
minimumReleaseAgeExclude[]=@types/*

# Refuse silent downgrades of pinned versions
trustPolicy=no-downgrade

# No lifecycle scripts (no dep here needs any)
ignore-scripts=true

# Strict peer dependencies — surface resolution issues at install time
strict-peer-dependencies=true
auto-install-peers=false

# Verify store integrity (detects tampered local pnpm store)
verify-store-integrity=true
