# fichier .env de base pour l'environnement de prod
# pour "hériter" de ce fichier, définir la variable d'environnement suivante:
# DOMIFA_ENV_PRESET=dist-prod.preset.env

# hérite de la config "dist.preset.env"
DOMIFA_ENV_PRESET_PARENT=dist.preset.env

# mails & sms (enable by default)
DOMIFA_EMAILS_ENABLE=true
DOMIFA_SMS_ENABLE=true

# Behavioural quotas: prod-grade thresholds (parent dist.preset.env sets 10
# for non-prod, we restore the production target here).
DOMIFA_QUOTA_USAGERS_DOCS_DOWNLOAD_PER_DAY=100
DOMIFA_QUOTA_USAGERS_DOCS_DOWNLOAD_BLOCK_PER_DAY=200
DOMIFA_QUOTA_USAGERS_DOCS_UPLOAD_PER_DAY=100
DOMIFA_QUOTA_USAGERS_DELETE_PER_DAY=100
DOMIFA_QUOTA_USAGERS_DELETE_BLOCK_PER_DAY=200

# cron
